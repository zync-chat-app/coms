# Zync comS Reference Implementation — Environment Configuration
# Copy to .env and fill in the values.
# Get SERVER_ID and CENTRAL_API_KEY from Central after registering your server.

# ── Identity ──────────────────────────────────────────────────────────────────
# The UUID assigned by Central when you registered this server
SERVER_ID=

# Human-readable display name (informational only)
SERVER_NAME=My Zync Server

# ── Server ────────────────────────────────────────────────────────────────────
ENV=dev
PORT=3000
LOG_LEVEL=info

# ── Central ───────────────────────────────────────────────────────────────────
# URL of the Zync Central server
CENTRAL_URL=http://localhost:8080

# API key issued by Central when this server was registered
CENTRAL_API_KEY=

# Ed25519 public key of Central — used to verify scoped tokens offline.
# Get this from your Central admin or the public documentation.
CENTRAL_PUBLIC_KEY=

# ── Crypto ────────────────────────────────────────────────────────────────────
# Ed25519 key pair for this comS — used to sign log chain entries.
# Generate with: go run cmd/keygen/main.go
SERVER_SECRET_KEY=
SERVER_PUBLIC_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=./data/messages.db
MAX_HISTORY_PER_REQUEST=100

# ── Features ──────────────────────────────────────────────────────────────────
FEATURE_TEXT_CHANNELS=true
FEATURE_ANNOUNCEMENT_CHANNELS=true
FEATURE_LOG_CHAIN=true

# 0 = unlimited connections
MAX_CONNECTIONS=0
